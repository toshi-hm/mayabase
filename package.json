{
  "name": "mayabase-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "fetch": "bun run scripts/fetch-videos.ts",
    "build": "astro build",
    "build:full": "bun run fetch && astro build",
    "preview": "bun run build && wrangler dev",
    "check": "astro check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "prettier --write \"**/*.astro\" && biome format --write .",
    "format:check": "prettier --check \"**/*.astro\" && biome format .",
    "test": "bun test",
    "generate-types": "wrangler types",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.0.7",
    "embla-carousel": "8.6.0",
    "embla-carousel-autoplay": "8.6.0",
    "fast-xml-parser": "5.9.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "2.5.3",
    "@tailwindcss/vite": "4.3.2",
    "@types/bun": "1.3.14",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "wrangler": "^4.110.0"
  }
}
