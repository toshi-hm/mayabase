---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { site } from "../config/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = `${site.name} | YouTube チャンネル公式ポータル`, description = site.description } =
  Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/ogp.png", Astro.site);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://i.ytimg.com" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#15151f" />
    <meta name="generator" content={Astro.generator} />

    {/* OGP */}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} - YouTube チャンネル公式ポータル`} />

    {/* X (Twitter) Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={`@${site.x.account}`} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <slot name="head" />
  </head>
  <body class="min-h-dvh antialiased">
    <a
      href="#main"
      class="sr-only rounded-full bg-brand px-4 py-2 font-semibold text-surface focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50"
    >
      本文へスキップ
    </a>
    <SiteHeader />
    <slot />
    <SiteFooter />
  </body>
</html>
