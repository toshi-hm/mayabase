---
import { site } from "../config/site";
import SectionHeading from "./SectionHeading.astro";
---

<section aria-labelledby="profile-heading" class="py-16">
  <SectionHeading id="profile-heading" title="プロフィール" />
  <div class="flex flex-col items-start gap-6 rounded-2xl bg-surface-raised p-8 sm:flex-row">
    <div
      class="grid h-20 w-20 flex-none place-items-center rounded-full bg-brand text-3xl font-bold text-surface"
      aria-hidden="true"
    >
      {site.profile.name.charAt(0)}
    </div>
    <div>
      <h3 class="text-xl font-bold">{site.profile.name}</h3>
      <p class="mt-1 text-sm text-ink-muted">{site.profile.role}</p>
      <p class="mt-4 leading-relaxed">{site.profile.bio}</p>
      <ul class="mt-5 flex flex-wrap gap-4 text-sm">
        <li>
          <a
            href={site.youtube.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand underline-offset-4 hover:underline"
          >
            YouTube: {site.youtube.handle}
          </a>
        </li>
        <li>
          <a
            href={site.x.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-brand underline-offset-4 hover:underline"
          >
            X: @{site.x.account}
          </a>
        </li>
      </ul>
    </div>
  </div>
</section>
