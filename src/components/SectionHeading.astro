---
interface Props {
  id: string;
  title: string;
  subtitle?: string;
}

const { id, title, subtitle } = Astro.props;
---

<div class="mb-8 max-w-2xl">
  <h2 id={id} class="text-2xl font-black sm:text-3xl">{title}</h2>
  {subtitle && <p class="mt-2 leading-relaxed text-ink-muted">{subtitle}</p>}
</div>
