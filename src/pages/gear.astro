---
import SectionHeading from "../components/SectionHeading.astro";
import { site } from "../config/site";
import gearJson from "../data/gear.json";
import Base from "../layouts/Base.astro";
import { GEAR_CATEGORY_LABELS, groupGearByCategory, parseGearData } from "../lib/gear";

const { items } = parseGearData(gearJson);
const groups = groupGearByCategory(items).filter(([, groupItems]) => groupItems.length > 0);

const pageTitle = `愛用ガジェット | ${site.name}`;
const pageDescription = `${site.name} の動画制作・デスク環境で実際に使っている機材とガジェットの一覧。キーボード・マイク・カメラからスマート家電まで、動画で気になったアイテムをまとめてチェックできます。`;

if (!Astro.site) {
  throw new Error("astro.config.mjs の site が未設定です(canonical / JSON-LD の生成に必須)");
}
const siteUrl = Astro.site.toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "ホーム", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "愛用ガジェット", item: `${siteUrl}gear/` },
      ],
    },
    {
      "@type": "ItemList",
      "@id": `${siteUrl}gear/#gear`,
      name: `${site.name} の愛用ガジェット一覧`,
      itemListElement: items.map((item, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: `${item.brand} ${item.name}`,
        url: item.url,
        ...(item.image ? { image: item.image } : {}),
      })),
    },
  ],
};
const jsonLdSafe = JSON.stringify(jsonLd).replace(/</g, "\\u003c");
---

<Base title={pageTitle} description={pageDescription}>
  <script is:inline type="application/ld+json" set:html={jsonLdSafe} slot="head" />
  <link rel="preconnect" href="https://m.media-amazon.com" crossorigin slot="head" />
  <main id="main" class="mx-auto max-w-6xl px-4 pt-12 pb-24">
    <h1 class="text-3xl font-bold sm:text-4xl">愛用ガジェット</h1>
    <div class="mt-3 grid gap-x-8 gap-y-5 lg:grid-cols-[minmax(0,1fr)_20rem]">
      <p class="max-w-2xl text-ink-muted lg:col-start-1 lg:row-start-1">
        動画制作やデスク環境で実際に使っている機材・ガジェットの一覧です。「動画に出てきたあれは何?」の答えがここにあります。
      </p>
      <div
        class="mx-auto flex w-fit flex-col items-center lg:col-start-2 lg:row-span-2 lg:row-start-1 lg:mx-0 lg:justify-self-end"
      >
        <a
          href="https://amzn.asia/d/07216xEl"
          target="_blank"
          rel="sponsored noopener noreferrer"
          class="inline-flex w-fit items-center gap-2 rounded-md border border-ink bg-surface px-4 py-2 text-sm font-semibold transition hover:bg-ink hover:text-white focus-visible:outline-2 focus-visible:outline-brand"
        >
          Amazon Storefrontを見る <span aria-hidden="true">↗</span>
          <span class="sr-only">(外部サイト・新しいタブで開きます)</span>
        </a>

        <div
          id="storefront-mascot"
          class="storefront-mascot relative mt-1 w-72 max-w-[78vw]"
          aria-live="off"
        >
          <img
            src="/images/storefront-bear.png"
            alt=""
            width="640"
            height="640"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="block h-auto w-full"
            aria-hidden="true"
          />
          <p
            class="absolute top-[44%] right-[17%] left-[17%] flex h-[28%] flex-col items-center justify-center text-center text-xs leading-snug font-semibold text-ink"
          >
            <span>Amazon Storefrontに</span>
            <span>最新のおすすめアイテム</span>
            <span>掲載中！</span>
          </p>
        </div>
      </div>

      {/* ステマ規制(景品表示法)対応: アフィリエイト広告を含む旨をファーストビューに明示する */}
      <p
        class="max-w-2xl self-start rounded-xl border border-ink-muted/40 bg-surface-raised p-4 text-sm text-ink-muted lg:col-start-1 lg:row-start-2"
      >
        <strong class="text-ink">【PR】</strong>
        本ページのリンクにはアフィリエイト広告(Amazon アソシエイト等)を含みます。リンク経由でご購入いただくと売上の一部がチャンネル運営の支えになります。いつもありがとうございます!
      </p>
    </div>

    {
      groups.map(([category, groupItems], groupIndex) => (
        <section aria-labelledby={`gear-${category}-heading`} class="pt-14">
          <SectionHeading id={`gear-${category}-heading`} title={GEAR_CATEGORY_LABELS[category]} />
          <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {groupItems.map((item, itemIndex) => (
              <li>
                <a
                  href={item.url}
                  target="_blank"
                  rel="sponsored noopener noreferrer"
                  class="group/card flex h-full flex-col overflow-hidden rounded-lg border border-line bg-surface transition hover:-translate-y-1 hover:shadow-lg focus-visible:outline-2 focus-visible:outline-brand"
                >
                  {item.image && (
                    <div class="grid aspect-[4/3] place-items-center bg-white p-6">
                      <img
                        src={item.image}
                        alt=""
                        width="800"
                        height="800"
                        loading={groupIndex === 0 && itemIndex === 0 ? "eager" : "lazy"}
                        fetchpriority={groupIndex === 0 && itemIndex === 0 ? "high" : "auto"}
                        decoding="async"
                        class="h-auto w-auto max-h-56 max-w-72 object-contain transition duration-300 group-hover/card:scale-[1.03]"
                      />
                    </div>
                  )}
                  <div class="flex flex-1 flex-col border-t border-line p-5">
                    <p class="text-xs font-semibold tracking-wider text-brand">{item.brand}</p>
                    <h3 class="mt-1 font-semibold leading-snug group-hover/card:text-brand">
                      {item.name}
                    </h3>
                    {item.note && <p class="mt-2 text-sm text-ink-muted">{item.note}</p>}
                    <p class="mt-auto pt-3 text-sm font-semibold text-brand">
                      詳細を見る<span aria-hidden="true"> →</span>
                      <span class="sr-only">(外部サイト・新しいタブで開きます)</span>
                    </p>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }

    <section aria-labelledby="gear-cta-heading" class="pt-16">
      <div class="rounded-2xl bg-surface-raised p-8 text-center">
        <h2 id="gear-cta-heading" class="text-xl font-bold">機材の使用感は動画でチェック</h2>
        <p class="mx-auto mt-2 max-w-xl text-ink-muted">
          レビュー動画やデスクツアーは YouTube チャンネルで公開しています。
        </p>
        <div class="mt-5 flex flex-wrap justify-center gap-4">
          <a
            href="/videos/"
            class="rounded-full bg-brand px-6 py-3 font-semibold text-surface transition hover:bg-brand-strong"
          >
            動画ライブラリを見る
          </a>
          <a
            href={site.youtube.url}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full border border-ink-muted px-6 py-3 font-semibold transition hover:border-ink hover:bg-surface"
          >
            YouTube チャンネルへ
          </a>
        </div>
      </div>
    </section>
  </main>

  <a
    id="storefront-floating"
    href="https://amzn.asia/d/07216xEl"
    target="_blank"
    rel="sponsored noopener noreferrer"
    aria-hidden="true"
    tabindex="-1"
    class="storefront-floating fixed right-3 bottom-3 z-50 w-28 sm:right-5 sm:bottom-5 sm:w-36"
  >
    <span class="sr-only">Amazon Storefrontを見る(外部サイト・新しいタブで開きます)</span>
    <span class="relative block drop-shadow-lg" aria-hidden="true">
      <img
        src="/images/storefront-bear.png"
        alt=""
        width="640"
        height="640"
        loading="lazy"
        decoding="async"
        class="block h-auto w-full"
      />
      <span
        class="absolute top-[44%] right-[17%] left-[17%] flex h-[28%] items-center justify-center text-center text-[9px] leading-tight font-semibold text-ink sm:text-[11px]"
      >
        Storefrontへ
      </span>
    </span>
  </a>
</Base>

<script>
  const storefrontMascot = document.getElementById("storefront-mascot");
  const floatingStorefront = document.getElementById("storefront-floating");

  if (storefrontMascot && floatingStorefront instanceof HTMLAnchorElement) {
    let ticking = false;

    const syncFloatingStorefront = () => {
      const isVisible = storefrontMascot.getBoundingClientRect().bottom <= 0;
      floatingStorefront.classList.toggle("is-visible", isVisible);
      floatingStorefront.setAttribute("aria-hidden", String(!isVisible));
      floatingStorefront.tabIndex = isVisible ? 0 : -1;
      ticking = false;
    };

    const requestSync = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(syncFloatingStorefront);
    };

    syncFloatingStorefront();
    window.addEventListener("scroll", requestSync, { passive: true });
    window.addEventListener("resize", requestSync);
  }
</script>

<style>
  .storefront-mascot {
    transform-origin: bottom center;
    animation: storefront-pop 760ms cubic-bezier(0.2, 0.8, 0.2, 1.15) 160ms both;
  }

  @keyframes storefront-pop {
    0% {
      transform: translateY(3rem) scale(0.92);
    }
    58% {
      transform: translateY(-0.45rem) scale(1.02);
    }
    78% {
      transform: translateY(0.2rem) scale(0.99);
    }
    100% {
      transform: translateY(0) scale(1);
    }
  }

  .storefront-floating {
    pointer-events: none;
    opacity: 0;
    transform: translateY(1.5rem) scale(0.82);
    transform-origin: bottom right;
    transition:
      opacity 180ms ease,
      transform 360ms cubic-bezier(0.2, 0.8, 0.2, 1.2);
  }

  .storefront-floating.is-visible {
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .storefront-floating.is-visible:hover {
    transform: translateY(-0.2rem) scale(1.04);
  }

  @media (prefers-reduced-motion: reduce) {
    .storefront-mascot {
      animation: none;
    }

    .storefront-floating {
      transition: none;
    }
  }
</style>
