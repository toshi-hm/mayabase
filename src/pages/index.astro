---
import Carousel from "../components/Carousel.astro";
import PostCard from "../components/PostCard.astro";
import Profile from "../components/Profile.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ShortCard from "../components/ShortCard.astro";
import VideoCard from "../components/VideoCard.astro";
import { site } from "../config/site";
import videosJson from "../data/videos.json";
import xPostsJson from "../data/x-posts.json";
import Base from "../layouts/Base.astro";
import { parseXPostsData } from "../lib/x";
import {
  embedUrl,
  parseVideosData,
  thumbnailFallbackUrl,
  thumbnailUrl,
  videoUrl,
} from "../lib/youtube";

const { maxItems } = site.carousel;
const { videos } = parseVideosData(videosJson);

// isShort: null(未判定)は横動画として表示する(docs/02-design.md)
const regularVideos = videos.filter((v) => v.isShort !== true).slice(0, maxItems);
const shortVideos = videos.filter((v) => v.isShort === true).slice(0, maxItems);

const { account, posts } = parseXPostsData(xPostsJson);
const xPosts = posts.slice(0, maxItems);

// JSON-LD 構造化データ(VideoObject は Google 必須の name / description / thumbnailUrl / uploadDate を含む)
if (!Astro.site) {
  throw new Error("astro.config.mjs の site が未設定です(canonical / JSON-LD の生成に必須)");
}
const siteUrl = Astro.site.toString();
const displayedVideos = [...regularVideos, ...shortVideos];
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}#website`,
      name: site.name,
      description: site.description,
      url: siteUrl,
      inLanguage: "ja",
      publisher: { "@id": `${siteUrl}#owner` },
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}#owner`,
      name: site.profile.name,
      description: site.profile.bio,
      url: siteUrl,
      sameAs: [site.youtube.url, site.x.url],
    },
    // 動画一覧の記述用(遷移先は youtube.com のためホストカルーセル要件の対象外)
    ...(displayedVideos.length > 0
      ? [
          {
            "@type": "ItemList",
            "@id": `${siteUrl}#videos`,
            name: `${site.name} の最新動画`,
            isPartOf: { "@id": `${siteUrl}#website` },
            itemListElement: displayedVideos.map((video, index) => ({
              "@type": "ListItem",
              position: index + 1,
              item: {
                "@type": "VideoObject",
                name: video.title,
                description: video.description || video.title,
                thumbnailUrl: [thumbnailUrl(video.id), thumbnailFallbackUrl(video.id)],
                uploadDate: video.publishedAt,
                embedUrl: embedUrl(video.id),
                url: videoUrl(video),
              },
            })),
          },
        ]
      : []),
  ],
};
const jsonLdSafe = JSON.stringify(jsonLd).replace(/</g, "\\u003c");
---

<Base>
  <script is:inline type="application/ld+json" set:html={jsonLdSafe} slot="head" />
  <main id="main">
    <section aria-labelledby="videos-heading" class="overflow-hidden border-b border-line pb-14">
      <div class="mx-auto max-w-6xl px-4 pt-8 sm:pt-10">
        <div class="mb-8 grid gap-5 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
          <div>
            <p class="mb-2 text-sm font-bold text-brand">ITで日常をより便利に</p>
            <h1 class="text-4xl font-black sm:text-6xl">{site.name}</h1>
          </div>
          <div class="lg:pb-1">
            <p class="leading-relaxed text-ink-muted">
              AI、ガジェット、働く日々のリアル。暮らしと仕事を少し便利にする発見を動画で届けます。
            </p>
            <nav
              aria-label="チャンネルリンク"
              class="mt-4 flex flex-wrap gap-4 text-sm font-semibold"
            >
              <a
                href={site.youtube.url}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-md bg-brand px-4 py-2 text-white transition hover:bg-brand-strong"
              >
                YouTube で見る <span aria-hidden="true">↗</span>
              </a>
              <a
                href="/videos/"
                class="px-1 py-2 underline decoration-line underline-offset-4 hover:text-brand"
              >
                すべての動画
              </a>
            </nav>
          </div>
        </div>
        <div class="mb-5 flex items-end justify-between gap-4 border-t border-line pt-5">
          <h2 id="videos-heading" class="text-xl font-black sm:text-2xl">最新動画</h2>
          <p class="hidden text-sm text-ink-muted sm:block">NEW RELEASES</p>
        </div>
        {
          regularVideos.length > 0 ? (
            <Carousel label="最新動画の一覧">
              {regularVideos.map((video, index) => (
                <VideoCard
                  video={video}
                  position={index + 1}
                  total={regularVideos.length}
                  eager={index === 0}
                  featured
                />
              ))}
            </Carousel>
          ) : (
            <p class="rounded-lg bg-surface-raised p-8 text-center text-ink-muted">
              動画データを準備中です。
              <a
                href={site.youtube.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-brand underline underline-offset-4"
              >
                YouTube チャンネル
              </a>
              で最新の動画をご覧ください。
            </p>
          )
        }
      </div>
    </section>

    <section aria-labelledby="shorts-heading" class="bg-surface-mint py-16">
      <div class="mx-auto max-w-6xl px-4">
        <SectionHeading
          id="shorts-heading"
          title="Shortsで、さっと発見"
          subtitle="移動中や休憩時間にも見やすい、短いアイデアと気づきをまとめました。"
        />
        {
          shortVideos.length > 0 ? (
            <Carousel label="Shorts の一覧">
              {shortVideos.map((video, index) => (
                <ShortCard video={video} position={index + 1} total={shortVideos.length} />
              ))}
            </Carousel>
          ) : (
            <p class="rounded-xl bg-surface-raised p-8 text-center text-ink-muted">
              Shorts データを準備中です。
              <a
                href={site.youtube.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-brand underline underline-offset-4"
              >
                YouTube チャンネル
              </a>
              でご覧ください。
            </p>
          )
        }
      </div>
    </section>

    <section aria-labelledby="x-heading" class="py-16">
      <div class="mx-auto max-w-6xl px-4">
        <SectionHeading
          id="x-heading"
          title="いま考えていること"
          subtitle={`@${account} から、動画になる前の気づきや日々の記録を。`}
        />
        {
          xPosts.length > 0 ? (
            <Carousel label="X ポストの一覧">
              {xPosts.map((post, index) => (
                <PostCard
                  post={post}
                  account={account}
                  position={index + 1}
                  total={xPosts.length}
                />
              ))}
            </Carousel>
          ) : (
            <p class="rounded-xl bg-surface-raised p-8 text-center text-ink-muted">
              ポストデータを準備中です。
              <a
                href={site.x.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-brand underline underline-offset-4"
              >
                X(@{account})
              </a>
              で最新の投稿をご覧ください。
            </p>
          )
        }
      </div>
    </section>

    <section class="bg-surface-sun">
      <div class="mx-auto max-w-6xl px-4">
        <Profile />
      </div>
    </section>
  </main>
</Base>
