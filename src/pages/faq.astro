---
import SectionHeading from "../components/SectionHeading.astro";
import { site } from "../config/site";
import faqJson from "../data/faq.json";
import Base from "../layouts/Base.astro";
import { isInternalPath, parseFaqData } from "../lib/faq";

const { categories } = parseFaqData(faqJson);
const allItems = categories.flatMap((category) => category.items);

const pageTitle = `よくある質問 | ${site.name}`;
const pageDescription = `${site.name} へのよくある質問。チャンネルの内容、運営者プロフィール、使用機材、お仕事のご依頼方法についてまとめています。`;

if (!Astro.site) {
  throw new Error("astro.config.mjs の site が未設定です(canonical / JSON-LD の生成に必須)");
}
const siteUrl = Astro.site.toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "ホーム", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "よくある質問", item: `${siteUrl}faq/` },
      ],
    },
    {
      "@type": "FAQPage",
      "@id": `${siteUrl}faq/#faq`,
      mainEntity: allItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
const jsonLdSafe = JSON.stringify(jsonLd).replace(/</g, "\\u003c");
---

<Base title={pageTitle} description={pageDescription}>
  <script is:inline type="application/ld+json" set:html={jsonLdSafe} slot="head" />
  <main id="main" class="mx-auto max-w-3xl px-4 pt-12 pb-24">
    <h1 class="text-3xl font-bold sm:text-4xl">よくある質問</h1>
    <p class="mt-3 text-ink-muted">
      チャンネルや運営者、機材、お仕事のご依頼についてよくいただく質問をまとめました。
    </p>

    {
      categories.map((category, categoryIndex) => (
        <section aria-labelledby={`faq-category-${categoryIndex}-heading`} class="pt-12">
          <SectionHeading id={`faq-category-${categoryIndex}-heading`} title={category.title} />
          <div class="flex flex-col gap-3">
            {category.items.map((item) => (
              <details class="group rounded-xl bg-surface-raised">
                <summary class="cursor-pointer list-none rounded-xl p-5 font-semibold transition hover:text-brand focus-visible:outline-2 focus-visible:outline-brand [&::-webkit-details-marker]:hidden">
                  <span class="flex items-start justify-between gap-4">
                    {item.question}
                    <span
                      aria-hidden="true"
                      class="flex-none text-ink-muted transition group-open:rotate-45"
                    >
                      +
                    </span>
                  </span>
                </summary>
                <div class="px-5 pb-5">
                  <p class="leading-relaxed text-ink-muted">{item.answer}</p>
                  {item.link &&
                    (isInternalPath(item.link.url) ? (
                      <a
                        href={item.link.url}
                        class="mt-3 inline-block text-brand underline-offset-4 hover:underline"
                      >
                        {item.link.label}
                      </a>
                    ) : (
                      <a
                        href={item.link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="mt-3 inline-block text-brand underline-offset-4 hover:underline"
                      >
                        {item.link.label}
                        <span class="sr-only">(外部サイト・新しいタブで開きます)</span>
                      </a>
                    ))}
                </div>
              </details>
            ))}
          </div>
        </section>
      ))
    }

    <section aria-labelledby="faq-cta-heading" class="pt-16">
      <div class="rounded-2xl bg-surface-raised p-8 text-center">
        <h2 id="faq-cta-heading" class="text-xl font-bold">解決しない質問がありますか?</h2>
        <p class="mx-auto mt-2 max-w-xl text-ink-muted">
          マシュマロで匿名の質問を受け付けています。いただいた質問には動画のネタとしてお答えします。
        </p>
        <div class="mt-5">
          <a
            href={site.marshmallow.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block rounded-full bg-brand px-6 py-3 font-semibold text-surface transition hover:bg-brand-strong"
          >
            マシュマロで質問を送る
          </a>
        </div>
      </div>
    </section>
  </main>
</Base>
