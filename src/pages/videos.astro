---
import ArchiveCard from "../components/ArchiveCard.astro";
import { site } from "../config/site";
import videosJson from "../data/videos.json";
import Base from "../layouts/Base.astro";
import { CATEGORY_LABELS, CATEGORY_ORDER, categorizeVideo } from "../lib/categories";
import { truncate } from "../lib/format";
import {
  embedUrl,
  parseVideosData,
  thumbnailFallbackUrl,
  thumbnailUrl,
  videoUrl,
} from "../lib/youtube";

const { videos } = parseVideosData(videosJson);
const categorized = videos.map((video) => ({ video, category: categorizeVideo(video) }));

// 動画が 1 件以上あるカテゴリだけをフィルタ UI に出す
const availableCategories = CATEGORY_ORDER.filter((category) =>
  categorized.some((entry) => entry.category === category),
);

const pageTitle = `動画ライブラリ | ${site.name}`;
const pageDescription = `${site.name} の全動画アーカイブ。AI・ガジェット/家電・社会人 Vlog・エンジニアキャリアのカテゴリやキーワードから過去の動画を探せます。`;

if (!Astro.site) {
  throw new Error("astro.config.mjs の site が未設定です(canonical / JSON-LD の生成に必須)");
}
const siteUrl = Astro.site.toString();
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "ホーム", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "動画ライブラリ", item: `${siteUrl}videos/` },
      ],
    },
    {
      "@type": "ItemList",
      "@id": `${siteUrl}videos/#videos`,
      name: `${site.name} の動画一覧`,
      itemListElement: videos.map((video, index) => ({
        "@type": "ListItem",
        position: index + 1,
        item: {
          "@type": "VideoObject",
          name: video.title,
          // 概要欄全文はハッシュタグや定型文が長く JSON-LD を肥大化させるため要約する
          description: truncate(video.description, 160) || video.title,
          thumbnailUrl: [thumbnailUrl(video.id), thumbnailFallbackUrl(video.id)],
          uploadDate: video.publishedAt,
          embedUrl: embedUrl(video.id),
          url: videoUrl(video),
        },
      })),
    },
  ],
};
const jsonLdSafe = JSON.stringify(jsonLd).replace(/</g, "\\u003c");
---

<Base title={pageTitle} description={pageDescription}>
  <script is:inline type="application/ld+json" set:html={jsonLdSafe} slot="head" />
  <main id="main" class="mx-auto max-w-6xl px-4 pt-12 pb-24">
    <h1 class="text-3xl font-bold sm:text-4xl">動画ライブラリ</h1>
    <p class="mt-3 max-w-2xl text-ink-muted">
      これまでに公開した全 {videos.length}
      本の動画アーカイブです。カテゴリやキーワードで気になる動画を探して、YouTube でご覧ください。
    </p>

    <section aria-label="動画の絞り込み" class="mt-8 flex flex-col gap-4">
      <div role="group" aria-label="カテゴリで絞り込み" class="flex flex-wrap gap-2">
        <button
          type="button"
          data-filter-category="all"
          aria-pressed="true"
          class="cursor-pointer rounded-full border border-ink-muted px-4 py-1.5 text-sm transition hover:border-ink focus-visible:outline-2 focus-visible:outline-brand aria-pressed:border-brand aria-pressed:bg-brand aria-pressed:font-semibold aria-pressed:text-surface"
        >
          すべて
        </button>
        {
          availableCategories.map((category) => (
            <button
              type="button"
              data-filter-category={category}
              aria-pressed="false"
              class="cursor-pointer rounded-full border border-ink-muted px-4 py-1.5 text-sm transition hover:border-ink focus-visible:outline-2 focus-visible:outline-brand aria-pressed:border-brand aria-pressed:bg-brand aria-pressed:font-semibold aria-pressed:text-surface"
            >
              {CATEGORY_LABELS[category]}
            </button>
          ))
        }
      </div>
      <div class="max-w-md">
        <label for="video-search" class="mb-1 block text-sm text-ink-muted">キーワード検索</label>
        <input
          id="video-search"
          type="search"
          placeholder="例: ChatGPT、家電、Vlog"
          class="w-full rounded-xl border border-ink-muted bg-surface-raised px-4 py-2 placeholder:text-ink-muted/60 focus-visible:outline-2 focus-visible:outline-brand"
        />
      </div>
      <p id="videos-count" aria-live="polite" class="text-sm text-ink-muted">
        {videos.length} 件
      </p>
    </section>

    {/* 見出し階層(h1→h2→h3)を保つためのセクション見出し(視覚上はフィルタ UI が境界) */}
    <h2 class="sr-only">動画一覧</h2>
    <ul id="videos-grid" class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {categorized.map(({ video, category }) => <ArchiveCard video={video} category={category} />)}
    </ul>
    <p id="videos-empty" hidden class="rounded-xl bg-surface-raised p-8 text-center text-ink-muted">
      条件に一致する動画が見つかりませんでした。カテゴリやキーワードを変えてお試しください。
    </p>
    {
      /*
      「もっと見る」ボタン。JS 無効時は全件が既に表示されているため hidden のまま
      (プログレッシブエンハンスメント)。JS 有効時のみスクリプトが必要に応じて表示する。
      一度押すと以降は全件表示のまま(このボタンは二度と表示されない)。
    */
    }
    <div class="mt-10 text-center">
      <button
        id="videos-more"
        type="button"
        hidden
        class="cursor-pointer rounded-full border border-ink-muted px-8 py-3 font-semibold transition hover:border-ink hover:bg-surface-raised focus-visible:outline-2 focus-visible:outline-brand"
      >
        もっと見る
      </button>
    </div>
  </main>
</Base>

<script>
  // 絞り込み・検索 + 段階表示(JS 無効時は全件表示のままになるプログレッシブエンハンスメント)
  const INITIAL_COUNT = 12; // 初期表示件数(超過分は「もっと見る」で展開)
  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-filter-category]");
  const search = document.getElementById("video-search") as HTMLInputElement | null;
  const cards = document.querySelectorAll<HTMLLIElement>("#videos-grid > li");
  const count = document.getElementById("videos-count");
  const empty = document.getElementById("videos-empty");
  const moreButton = document.getElementById("videos-more") as HTMLButtonElement | null;
  let category = "all";
  // 一度展開したら以降は全件表示のまま(ボタンは二度と出さない)
  let expanded = false;

  function cardMatches(card: HTMLLIElement, query: string): boolean {
    return (
      (category === "all" || card.dataset.category === category) &&
      (query === "" || (card.dataset.title ?? "").includes(query))
    );
  }

  function applyFilter(): void {
    const query = (search?.value ?? "").trim().toLowerCase();
    let matched = 0; // 条件に一致する総数
    let shown = 0; // 実際に表示している数(未展開時は INITIAL_COUNT で頭打ち)
    for (const card of cards) {
      if (cardMatches(card, query)) {
        matched += 1;
        const withinLimit = expanded || matched <= INITIAL_COUNT;
        card.hidden = !withinLimit;
        if (withinLimit) shown += 1;
      } else {
        card.hidden = true;
      }
    }
    if (count) count.textContent = `${matched} 件`;
    if (empty) empty.hidden = matched > 0;

    const remaining = matched - shown;
    if (moreButton) {
      if (!expanded && remaining > 0) {
        moreButton.hidden = false;
        moreButton.textContent = `もっと見る(残り ${remaining} 件)`;
      } else {
        moreButton.hidden = true;
      }
    }
  }

  for (const button of buttons) {
    button.addEventListener("click", () => {
      category = button.dataset.filterCategory ?? "all";
      for (const other of buttons) {
        other.setAttribute("aria-pressed", String(other === button));
      }
      applyFilter();
    });
  }
  search?.addEventListener("input", applyFilter);

  moreButton?.addEventListener("click", () => {
    // 展開直前に「これから現れる最初のカード」を控えておき、展開後にフォーカスを移す
    const query = (search?.value ?? "").trim().toLowerCase();
    const firstRevealed = [...cards].find((card) => card.hidden && cardMatches(card, query));
    expanded = true;
    applyFilter();
    firstRevealed?.querySelector("a")?.focus();
  });

  // 初期表示:件数が INITIAL_COUNT を超えていれば頭打ち + ボタン表示
  applyFilter();
</script>
